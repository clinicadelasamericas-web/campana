<script>
function showPanel(id, btn) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.getElementById('panel-' + id).classList.add('active');
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active', 'verde', 'celeste', 'naranja'));
  btn.classList.add('active');
  const colors = { consultorio: 'verde', laboratorios: 'naranja', paquetes: 'celeste', cirugias: 'naranja', maternidad: 'celeste' };
  if (colors[id]) btn.classList.add(colors[id]);
}
</script>
